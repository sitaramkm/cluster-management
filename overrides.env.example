# overrides.env.example — copy to overrides.env and fill in your values.
# overrides.env is .gitignored and always loaded first, so every variable here wins.
# All variables must use "export" or Terraform will not see them.

# ---- Identity ----
export TF_VAR_resource_prefix="demo-001"
export TF_VAR_owner="demo-owner-name"

# ---- AWS ----
export TF_VAR_aws_profile="default"

# ---- Azure ----
# Required: Azure CLI must be authenticated to this tenant/subscription.
export TF_VAR_azure_subscription_id="00000000-0000-0000-0000-000000000000"
export TF_VAR_azure_tenant_id="00000000-0000-0000-0000-000000000000"

# ---- GCP ----
# Required: gcloud must be authenticated to this project.
export TF_VAR_gcp_project_id="my-gcp-project-id"
export TF_VAR_gcp_zone="my-gcp-zone"

# ---- Kubernetes version ----
# Uncomment to pin a version across all providers; provider-specific vars take precedence.
#export TF_VAR_k8s_version="1.35"

# ---- IP allowlist ----
# Your local public IP is always added automatically.
# List additional CIDRs as a JSON array if needed.
#export TF_VAR_allowed_additional_CIDR='["192.168.0.0/16","1.3.4.1/32","2.3.0.0/16"]'

# ---- Tags / Labels ----
# Uncomment and edit to override tags for a specific provider.
# AWS and Azure use map with any-case keys; GCP labels require lowercase keys.
#export TF_VAR_aws_tags='{"CreatedBy":"me","Environment":"prod","Team":"platform"}'
#export TF_VAR_azure_tags='{"CreatedBy":"me","Environment":"prod","Team":"platform"}'
#export TF_VAR_gcp_labels='{"created_by":"me","environment":"prod","team":"platform"}'
