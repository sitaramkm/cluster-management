# All common variables should be defined here
# No secrets, keys or passwords should be defined here

# set in overrides.env if you want to override; otherwise, defaults will be used.

# Prefix for all resources created by the scripts. 
# Must be 3-6 lowercase letters followed by a hyphen (e.g., "abc-"). 
# This helps avoid naming conflicts and makes it easier to identify resources created by this project.
export TF_VAR_resource_prefix="${TF_VAR_resource_prefix:-demo}" 
export TF_VAR_owner="${TF_VAR_owner:-me}"

export TF_VAR_k8s_version="1.35"

export TF_VAR_allowed_additional_CIDR="${TF_VAR_allowed_additional_CIDR:-[]}"
