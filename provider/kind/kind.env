#!/usr/bin/env bash
# kind.env — kind-specific variables
# Override in overrides.env; these defaults apply when not set.
# Falls back to TF_VAR_* for a single override path — add KIND_* to overrides.env
# when you need kind-specific values that differ from your cloud provider settings.

# ---- Cluster naming ----
KIND_CLUSTER_NAME="${KIND_CLUSTER_NAME:-${TF_VAR_cluster_name:-${TF_VAR_resource_prefix:-demo}-kind}}"
KIND_NODE_IMAGE="${KIND_NODE_IMAGE:-}"  # empty = use kind's bundled default image

# ---- Derived node names (not user-settable; kind always uses these) ----
KIND_CONTROL_PLANE_NODE="${KIND_CLUSTER_NAME}-control-plane"
KIND_WORKER_NODE="${KIND_CLUSTER_NAME}-worker"

# ---- OIDC (optional — set in overrides.env to enable external OIDC via GitHub Pages) ----
# No defaults — absence means kind uses its local OIDC (https://kubernetes.default.svc)
#   export KIND_OIDC_URL=https://sitaramkm.github.io/<cluster-name>
#   export KIND_GITHUB_PAGES_DIR=/path/to/local/sitaramkm.github.io
