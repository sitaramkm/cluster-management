#!/usr/bin/env bash
# azure.env — AKS-specific environment variables
# Override in overrides.env; these defaults apply when not set.

# ---- Access ----
TF_VAR_azure_subscription_id="${TF_VAR_azure_subscription_id:-00000000-0000-0000-0000-000000000000}"
TF_VAR_azure_tenant_id="${TF_VAR_azure_tenant_id:-00000000-0000-0000-0000-000000000000}"

# ---- Naming ----
TF_VAR_cluster_name="${TF_VAR_cluster_name:-${TF_VAR_resource_prefix}-aks}"
TF_VAR_resource_group="${TF_VAR_resource_group:-${TF_VAR_cluster_name}-rg}"

# ---- Region and node size (paired — check VM availability in your region) ----
TF_VAR_azure_location="${TF_VAR_azure_location:-southcentralus}"
TF_VAR_aks_node_vm_size="${TF_VAR_aks_node_vm_size:-Standard_D2s_v5}"

# ---- Node pool sizing ----
TF_VAR_aks_node_count="${TF_VAR_aks_node_count:-3}"

# ---- Kubernetes version ----
TF_VAR_aks_k8s_version="${TF_VAR_aks_k8s_version:-${TF_VAR_k8s_version:-1.34}}"

# ---- Networking ----
TF_VAR_aks_network_plugin="${TF_VAR_aks_network_plugin:-azure}"  # azure (native) or kubenet

# ---- SSH controls ----
TF_VAR_aks_no_ssh_key="${TF_VAR_aks_no_ssh_key:-true}"
TF_VAR_aks_disable_ssh_service="${TF_VAR_aks_disable_ssh_service:-true}"
TF_VAR_aks_ssh_public_key="${TF_VAR_aks_ssh_public_key:-}"

# ---- Cleanup behavior ----
TF_VAR_delete_resource_group_on_cleanup="${TF_VAR_delete_resource_group_on_cleanup:-true}"
TF_VAR_get_credentials_after_create="${TF_VAR_get_credentials_after_create:-true}"

# ---- Tags (JSON map) ----
# Azure tag keys are case-insensitive; values max 256 chars.
# Set in overrides.env to override all tags, e.g.:
#   export TF_VAR_azure_tags='{"CreatedBy":"me","Environment":"prod","Team":"platform"}'
if [[ -z "${TF_VAR_azure_tags:-}" ]]; then
    TF_VAR_azure_tags="{\"CreatedBy\":\"${TF_VAR_owner}\",\"Environment\":\"dev\",\"Team\":\"platform\"}"
fi
