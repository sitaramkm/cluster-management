#!/bin/bash
# gcp.env — GCP-specific environment variables
# Override in overrides.env; these defaults apply when not set.

# ---- GCP Environment ----
TF_VAR_gcp_project_id="${TF_VAR_gcp_project_id:-default}"
TF_VAR_gcp_region="${TF_VAR_gcp_region:-us-central1}"
TF_VAR_gcp_zone="${TF_VAR_gcp_zone:-default}"

# ---- GKE Cluster Setup ----
TF_VAR_cluster_name="${TF_VAR_cluster_name:-${TF_VAR_resource_prefix}-gke}"
TF_VAR_gke_k8s_version="${TF_VAR_gke_k8s_version:-${TF_VAR_k8s_version:-1.34}}"
TF_VAR_gke_release_channel="${TF_VAR_gke_release_channel:-regular}"  # rapid, regular, stable
TF_VAR_nodes="${TF_VAR_nodes:-4}"
TF_VAR_node_type="${TF_VAR_node_type:-e2-standard-4}"

# ---- Labels (JSON map) ----
# GCP labels must be lowercase keys, max 63 chars, values max 63 chars.
# Set in overrides.env to override all labels, e.g.:
#   export TF_VAR_gcp_labels='{"created_by":"me","environment":"prod","team":"platform"}'
if [[ -z "${TF_VAR_gcp_labels:-}" ]]; then
    TF_VAR_gcp_labels="{\"created_by\":\"${TF_VAR_owner}\",\"environment\":\"dev\",\"team\":\"platform\"}"
fi
