#!/bin/bash
# aws.env — AWS-specific environment variables
# Override in overrides.env; these defaults apply when not set.

# ---- Cluster Setup ----
export TF_VAR_cluster_name="${TF_VAR_cluster_name:-${TF_VAR_resource_prefix}-eks}"
export TF_VAR_aws_region="${TF_VAR_aws_region:-us-east-2}"
export TF_VAR_aws_profile="${TF_VAR_aws_profile:-default}"
export TF_VAR_eks_k8s_version="${TF_VAR_eks_k8s_version:-${TF_VAR_k8s_version:-1.35}}"

# ---- Default node group ----
export TF_VAR_nodegroup_name="${TF_VAR_nodegroup_name:-${TF_VAR_resource_prefix}-ng}"
export TF_VAR_node_type="${TF_VAR_node_type:-t3.medium}"
export TF_VAR_nodes="${TF_VAR_nodes:-3}"
export TF_VAR_nodes_min="${TF_VAR_nodes_min:-2}"
export TF_VAR_nodes_max="${TF_VAR_nodes_max:-3}"

# ---- Features ----
export TF_VAR_enable_oidc="${TF_VAR_enable_oidc:-true}"
export TF_VAR_managed_nodegroup="${TF_VAR_managed_nodegroup:-true}"

# ---- VPC ----
export TF_VAR_vpc_cidr="${TF_VAR_vpc_cidr:-10.0.0.0/16}"

# ---- Tags (JSON map) ----
# Set in overrides.env to override all tags, e.g.:
#   export TF_VAR_aws_tags='{"CreatedBy":"me","Environment":"prod","Team":"platform"}'
if [[ -z "${TF_VAR_aws_tags:-}" ]]; then
    export TF_VAR_aws_tags="{\"CreatedBy\":\"${TF_VAR_owner}\",\"Environment\":\"dev\",\"Team\":\"platform\"}"
fi