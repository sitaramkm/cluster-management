#!/bin/bash
# aws.env — AWS Specific environment variables

# Override in overrides.env if needed; otherwise, these defaults will be used when creating an EKS cluster.

# ---- Cluster Setup ----

TF_VAR_cluster_name="${TF_VAR_cluster_name:-${TF_VAR_resource_prefix}-eks}"
TF_VAR_aws_region="${TF_VAR_aws_region:-us-east-2}"
TF_VAR_aws_profile="${TF_VAR_aws_profile:-default}"
TF_VAR_eks_k8s_version="${TF_VAR_eks_k8s_version:-1.34}}"

# ---- Default Linux node group ----
TF_VAR_nodegroup_name="${TF_VAR_nodegroup_name:-${TF_VAR_resource_prefix}-ng}"
TF_VAR_node_type="${TF_VAR_node_type:-t3.medium}"
TF_VAR_nodes="${TF_VAR_nodes:-4}"
TF_VAR_nodes_min="${TF_VAR_nodes_min:-3}"
TF_VAR_nodes_max="${TF_VAR_nodes_max:-4}"

# ---- Features ----
TF_VAR_enable_oidc="${TF_VAR_enable_oidc:-true}"
TF_VAR_managed_nodegroup="${TF_VAR_managed_nodegroup:-true}"

# ---- Tags ----
TF_VAR_aws_tags="${TF_VAR_aws_tags:-CreatedBy=${TF_VAR_owner},Environment=dev,Team=platform}"

