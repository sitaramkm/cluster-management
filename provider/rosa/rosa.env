#!/bin/bash

# === Cluster Config ===
TF_VAR_rosa_version="${TF_VAR_rosa_version:-4.18.20}"
TF_VAR_rosa_cluster_name="${TF_VAR_rosa_cluster_name:-${TF_VAR_resource_prefix}-rosa}"
TF_VAR_rosa_region="${TF_VAR_rosa_region:-us-east-2}"
TF_VAR_rosa_aws_roles_prefix="${TF_VAR_rosa_aws_roles_prefix:-${TF_VAR_rosa_cluster_name}}"
TF_VAR_rosa_domain_prefix="${TF_VAR_rosa_domain_prefix:-${TF_VAR_rosa_cluster_name}}"
TF_VAR_rosa_profile="${TF_VAR_rosa_profile:-${TF_VAR_aws_profile:-default}}"

# if your AWS and Redhat subscriptions are not connected, set hosted_control_plane setting = false for classic cluster
#export ROSA_HOSTED_CP=true
TF_VAR_rosa_hosted_cp="${TF_VAR_rosa_hosted_cp:-true}"  # true for hosted control plane (default), false for classic cluster

# === Networking ===
TF_VAR_rosa_network_stack_name="${TF_VAR_rosa_network_stack_name:-${TF_VAR_rosa_cluster_name}-nw-stack}"

PASS_SUFFIX="$(date +%S%H%M%d%m)"
TF_VAR_rosa_admin_password="${TF_VAR_rosa_admin_password:-"demoadmin-${PASS_SUFFIX}"}"

# === Tagging ===
TF_VAR_rosa_tags="${TF_VAR_rosa_tags:-CreatedBy=${TF_VAR_owner},Environment=dev,Team=platform}"

